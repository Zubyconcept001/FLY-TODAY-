.modal-content {
  background: white;
  border-radius: var(--radius);
  padding: 2.5rem;
  max-width: 600px;
  width: 100%;
  max-height: 90vh;
  overflow-y: auto;
  animation: scaleIn 0.3s ease;
  box-shadow: 0 25px 60px rgba(10, 37, 64, 0.3);
}

.modal-sm {
  max-width: 480px;
}

.modal-lg {
  max-width: 900px;
}

.modal-xl {
  max-width: 1200px;
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.75rem;
}

.modal-header h2 {
  color: var(--primary);
  font-weight: 800;
}

.close-btn {
  background: none;
  border: none;
  font-size: 1.75rem;
  cursor: pointer;
  color: var(--gray);
  transition: var(--transition);
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
}

.close-btn:hover {
  color: var(--danger);
  background: rgba(239, 68, 68, 0.1);
}

.auth-tabs {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 1.75rem;
  background: #f1f5f9;
  padding: 0.375rem;
  border-radius: 12px;
}

.auth-tab {
  flex: 1;
  padding: 0.75rem;
  background: none;
  border: none;
  font-weight: 700;
  color: var(--gray);
  cursor: pointer;
  border-radius: 8px;
  transition: var(--transition);
}

.auth-tab.active {
  background: white;
  color: var(--primary);
  box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}

.divider {
  display: flex;
  align-items: center;
  text-align: center;
  margin: 1.75rem 0;
  color: var(--gray);
  font-size: 0.875rem;
  font-weight: 600;
}

.divider::before,
.divider::after {
  content: '';
  flex: 1;
  border-bottom: 2px solid #e2e8f0;
}

.divider:not(:empty)::before {
  margin-right: 1rem;
}

.divider:not(:empty)::after {
  margin-left: 1rem;
}

.reservations-section {
  padding: 4rem 0;
  background: white;
}

.section-title {
  font-size: 2.25rem;
  font-weight: 900;
  margin-bottom: 2.5rem;
  text-align: center;
  color: var(--primary);
  letter-spacing: -0.02em;
}

.features {
  padding: 4rem 0;
  background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 2rem;
}

.feature-card {
  background: white;
  padding: 2.5rem;
  border-radius: var(--radius);
  text-align: center;
  box-shadow: var(--shadow-sm);
  transition: var(--transition);
  border: 1px solid rgba(10, 37, 64, 0.06);
}

.feature-card:hover {
  transform: translateY(-8px);
  box-shadow: var(--shadow);
  border-color: var(--secondary);
}

.feature-icon {
  width: 72px;
  height: 72px;
  margin: 0 auto 1.5rem;
  background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 2rem;
  box-shadow: 0 8px 20px rgba(0, 212, 255, 0.3);
}

.feature-card h3 {
  color: var(--primary);
  font-size: 1.25rem;
  font-weight: 800;
  margin-bottom: 0.75rem;
}

.feature-card p {
  color: var(--gray);
  font-weight: 500;
  line-height: 1.7;
}

footer {
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: white;
  padding: 4rem 0 1.5rem;
  margin-top: 4rem;
}

.footer-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 3rem;
  margin-bottom: 3rem;
}

.footer-grid h3 {
  font-weight: 800;
  margin-bottom: 1rem;
  font-size: 1.125rem;
}

.footer-bottom {
  text-align: center;
  padding-top: 2rem;
  border-top: 1px solid rgba(255, 255, 255, 0.15);
  font-size: 0.875rem;
  color: rgba(255, 255, 255, 0.7);
  font-weight: 500;
}

.footer-contact {
  line-height: 2.2;
}

.footer-contact a {
  color: rgba(255,255,255,0.85);
  text-decoration: none;
  transition: var(--transition);
  font-weight: 500;
}

.footer-contact a:hover {
  color: var(--secondary);
}

.badge {
  display: inline-block;
  padding: 0.375rem 1rem;
  border-radius: 20px;
  font-size: 0.8125rem;
  font-weight: 700;
  letter-spacing: 0.02em;
}

.badge-success {
  background: rgba(16, 185, 129, 0.15);
  color: var(--success);
}

.badge-warning {
  background: rgba(0, 212, 255, 0.15);
  color: var(--secondary);
}

.badge-danger {
  background: rgba(239, 68, 68, 0.15);
  color: var(--danger);
}

.badge-global {
  background: rgba(0, 212, 255, 0.15);
  color: var(--secondary);
}

.toast {
  position: fixed;
  bottom: 2rem;
  right: 2rem;
  background: white;
  padding: 1.25rem 1.75rem;
  border-radius: 12px;
  box-shadow: 0 10px 40px rgba(10, 37, 64, 0.2);
  display: none;
  z-index: 3000;
  border-left: 4px solid var(--success);
  max-width: 380px;
  font-weight: 600;
}

.toast.active {
  display: block;
  animation: slideInRight 0.4s ease;
}

@keyframes slideInRight {
  from {
    opacity: 0;
    transform: translateX(100px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.loading-spinner {
  border: 3px solid #e2e8f0;
  border-top: 3px solid var(--secondary);
  border-radius: 50%;
  width: 48px;
  height: 48px;
  animation: spin 1s linear infinite;
  margin: 2rem auto;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.firebase-notice {
  background: #fffbeb;
  border: 2px solid #f59e0b;
  border-radius: 12px;
  padding: 1.25rem;
  margin: 1.5rem 0;
  font-size: 0.9rem;
  font-weight: 500;
}

.error-msg {
  color: var(--danger);
  font-size: 0.875rem;
  margin-top: 0.5rem;
  display: none;
  font-weight: 600;
}

.error-msg.show {
  display: block;
}

.whatsapp-float {
  position: fixed;
  width: 64px;
  height: 64px;
  bottom: 2rem;
  left: 2rem;
  background: linear-gradient(135deg, var(--whatsapp) 0%, #20ba5a 100%);
  color: white;
  border-radius: 50%;
  text-align: center;
  font-size: 32px;
  box-shadow: 0 8px 24px rgba(37, 211, 102, 0.4);
  z-index: 1500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: var(--transition);
  animation: pulse 3s infinite;
}

.whatsapp-float:hover {
  transform: scale(1.1);
  box-shadow: 0 12px 32px rgba(37, 211, 102, 0.6);
}

@keyframes pulse {
  0%, 100% {
    box-shadow: 0 8px 24px rgba(37, 211, 102, 0.4);
  }
  50% {
    box-shadow: 0 8px 24px rgba(37, 211, 102, 0.4), 0 0 0 15px rgba(37, 211, 102, 0);
  }
}

.whatsapp-float svg {
  width: 34px;
  height: 34px;
}

.currency-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  padding: 0.25rem 0.625rem;
  background: rgba(0, 212, 255, 0.12);
  border-radius: 6px;
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--accent);
}

.payment-processing {
  display: none;
  text-align: center;
  padding: 2rem;
}

.payment-processing.active {
  display: block;
}

.qr-container {
  display: none;
  text-align: center;
}

.boarding-pass {
  background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
  border: 2px solid var(--secondary);
  border-radius: var(--radius);
  padding: 2rem;
  margin: 1.5rem 0;
}

.boarding-pass-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 1.5rem;
  border-bottom: 2px dashed #e2e8f0;
  margin-bottom: 1.5rem;
}

.pnr-badge {
  background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
  color: white;
  padding: 0.5rem 1.25rem;
  border-radius: 8px;
  font-size: 1.125rem;
  font-weight: 800;
  letter-spacing: 0.1em;
}

.boarding-pass-details {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
  margin-bottom: 1.5rem;
}

.detail-item {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.detail-label {
  font-size: 0.75rem;
  color: var(--gray);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.detail-value {
  font-size: 1.125rem;
  color: var(--dark);
  font-weight: 700;
}

.wallet-buttons {
  display: flex;
  gap: 1rem;
  margin-top: 1.5rem;
}

.wallet-buttons .btn {
  flex: 1;
}

#qrReader {
  width: 100%;
  border-radius: 12px;
  overflow: hidden;
  background: #f8fafc;
}

#qrScannerContainer {
  padding: 1.5rem;
}

.scanner-status {
  text-align: center;
  padding: 2rem;
  color: var(--gray);
}

.admin-table {
  width: 100%;
  border-collapse: collapse;
  background: white;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.admin-table th {
  background: var(--primary);
  color: white;
  padding: 1rem;
  text-align: left;
  font-weight: 700;
  font-size: 0.875rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.admin-table td {
  padding: 1rem;
  border-bottom: 1px solid #e2e8f0;
  font-size: 0.9rem;
}

.admin-table tr:hover {
  background: #f8fafc;
}

.admin-table tr:last-child td {
  border-bottom: none;
}

.filter-bar {
  display: flex;
  gap: 1rem;
  margin-bottom: 2rem;
  flex-wrap: wrap;
}

.filter-bar input {
  flex: 1;
  min-width: 200px;
  padding: 0.875rem 1rem;
  border: 2px solid #e2e8f0;
  border-radius: 10px;
  font-size: 0.9375rem;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1.5rem;
  margin-bottom: 2rem;
}

.stat-card {
  background: white;
  padding: 1.5rem;
  border-radius: 12px;
  box-shadow: var(--shadow-sm);
  border-left: 4px solid var(--secondary);
}

.stat-card h4 {
  font-size: 0.875rem;
  color: var(--gray);
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.5rem;
}

.stat-card .stat-value {
  font-size: 2rem;
  font-weight: 800;
  color: var(--primary);
}

.notification-banner {
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.1) 0%, rgba(16, 185, 129, 0.05) 100%);
  border: 2px solid rgba(16, 185, 129, 0.3);
  border-radius: 12px;
  padding: 1.25rem;
  margin-bottom: 1.5rem;
  display: none;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.notification-banner.show {
  display: flex;
  animation: slideInRight 0.4s ease;
}

.notification-banner p {
  margin: 0;
  font-weight: 600;
  color: var(--dark);
}

.notification-banner button {
  flex-shrink: 0;
}

@media (max-width: 768px) {
  .logo-wordmark {
    font-size: 1.375rem;
  }

  .logo-tagline {
    font-size: 0.575rem;
  }

  .logo-icon {
    width: 44px;
    height: 44px;
  }

  nav ul {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: white;
    flex-direction: column;
    padding: 1rem;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    gap: 0;
  }

  nav ul.active {
    display: flex;
  }

  nav ul li {
    width: 100%;
    padding: 0.75rem 0;
    border-bottom: 1px solid #e2e8f0;
  }

  .mobile-menu-btn {
    display: block;
  }

  .auth-section {
    flex-direction: column;
    align-items: stretch;
  }

  .select-group {
    flex-direction: column;
  }

  .flight-route {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .form-grid {
    grid-template-columns: 1fr;
  }

  .user-name {
    display: none;
  }

  .whatsapp-float {
    bottom: 1.5rem;
    left: 1.5rem;
    width: 56px;
    height: 56px;
  }

  .section-title {
    font-size: 1.75rem;
  }

  .wallet-buttons {
    flex-direction: column;
  }

  .boarding-pass-details {
    grid-template-columns: 1fr;
  }

  .filter-bar {
    flex-direction: column;
  }

  .filter-bar input {
    min-width: 100%;
  }
}
</style>
</head>
<body>
<header>
  <div class="container">
    <div class="header-content">
      <div class="logo-wrapper">
        <a href="#home" class="logo-link" onclick="showHome()">
          <div class="logo-icon">
            <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
              <defs>
                <linearGradient id="iconGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" style="stop-color:#00D4FF;stop-opacity:1" />
                  <stop offset="100%" style="stop-color:#0A2540;stop-opacity:1" />
                </linearGradient>
                <filter id="shadow">
                  <feDropShadow dx="0" dy="2" stdDeviation="3" flood-color="#0A2540" flood-opacity="0.2"/>
                </filter>
              </defs>
              <circle cx="50" cy="50" r="48" fill="url(#iconGradient)" filter="url(#shadow)"/>
              <circle cx="50" cy="50" r="46" fill="none" stroke="white" stroke-width="2" opacity="0.3"/>
              <path d="M 30 52 L 48 48 L 70 52 L 66 56 L 48 53 L 30 56 L 34 54 L 30 52 Z M 48 48 L 52 35 L 50 33 L 46 33 L 48 48 Z" fill="white"/>
              <path d="M 48 53 L 52 65 L 50 67 L 46 67 L 48 53 Z" fill="white" opacity="0.9"/>
              <ellipse cx="48" cy="48" rx="3" ry="2" fill="white" opacity="0.8"/>
            </svg>
          </div>
          <div class="logo-text-group">
            <div class="logo-wordmark">flytodayng.com</div>
            <div class="logo-tagline" data-i18n="tagline">Global Flights & Logistics</div>
          </div>
        </a>
      </div>
      <nav>
        <button class="mobile-menu-btn" onclick="toggleMenu()">☰</button>
        <ul id="navMenu">
          <li><a href="#home" onclick="showHome()" data-i18n="nav_home">Home</a></li>
          <li><a href="#flights" onclick="showHome()" data-i18n="nav_flights">Flights</a></li>
          <li><a href="/checkin" onclick="showCheckin(event)" data-i18n="nav_checkin">Check-In</a></li>
          <li><a href="#logistics" onclick="showHome()" data-i18n="nav_logistics">Logistics</a></li>
          <li><a href="#reservations" onclick="showHome()" data-i18n="nav_bookings">My Bookings</a></li>
          <li><a href="/admin" onclick="showAdmin(event)" id="adminLink" style="display:none;" data-i18n="nav_admin">Admin</a></li>
          <li><a href="#contact" onclick="showHome()" data-i18n="nav_contact">Contact</a></li>
        </ul>
        <div class="auth-section">
          <div class="select-group">
            <select class="language-selector" id="languageSelector" onchange="changeLanguage()">
              <option value="en">🇺🇸 EN</option>
            </select>
            <select class="currency-selector" id="currencySelector" onchange="changeCurrency()">
              <option value="USD">💵 USD</option>
              <option value="EUR">💶 EUR</option>
              <option value="GBP">💷 GBP</option>
              <option value="NGN">🇳🇬 NGN</option>
            </select>
          </div>
          <button class="google-signin-btn" id="signInBtn" onclick="openAuthModal()">
            <svg width="18" height="18" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
            </svg>
            <span data-i18n="signin">Sign in</span>
          </button>
          <div class="user-badge" id="userBadge" onclick="toggleUserMenu()">
            <img src="" alt="User" class="user-avatar" id="userAvatar">
            <span class="user-name" id="userName"></span>
          </div>
          <button class="btn btn-secondary btn-sm" id="signOutBtn" style="display:none;" onclick="signOut()" data-i18n="signout">Sign Out</button>
        </div>
      </nav>
    </div>
  </div>
</header>

<main id="mainContent">
  <div class="notification-banner" id="notificationBanner">
    <p id="notificationText"></p>
    <div>
      <button class="btn btn-secondary btn-sm" onclick="enableNotifications()" data-i18n="enable_notifications">Enable Notifications</button>
      <button class="close-btn" onclick="dismissNotificationBanner()">&times;</button>
    </div>
  </div>

  <section class="hero" id="home">
    <div class="container">
      <p class="hero-subtitle" data-i18n="hero_subtitle">🌍 Book flights to 5000+ destinations worldwide with premium service</p>
      <div class="search-card">
        <div class="tabs">
          <button class="tab active" onclick="switchTab('flights')" data-i18n="tab_flights">✈️ Flights</button>
          <button class="tab" onclick="switchTab('logistics')" data-i18n="tab_logistics">📦 Logistics</button>
        </div>
        
        <div id="flightsTab" class="tab-content">
          <form id="searchForm" onsubmit="searchFlights(event)">
            <div class="form-grid">
              <div class="form-group">
                <label data-i18n="form_from">From</label>
                <select id="fromCountry" required onchange="updateAirports('from')">
                  <option value="" data-i18n="select_country">Select Country</option>
                </select>
                <select id="fromAirport" required style="margin-top:0.5rem;">
                  <option value="" data-i18n="select_airport">Select Airport</option>
                </select>
              </div>
              <div class="form-group">
                <label data-i18n="form_to">To</label>
                <select id="toCountry" required onchange="updateAirports('to')">
                  <option value="" data-i18n="select_country">Select Country</option>
                </select>
                <select id="toAirport" required style="margin-top:0.5rem;">
                  <option value="" data-i18n="select_airport">Select Airport</option>
                </select>
              </div>
              <div class="form-group">
                <label data-i18n="form_departure">Departure Date</label>
                <input type="date" id="departDate" required>
              </div>
              <div class="form-group">
                <label data-i18n="form_passengers">Passengers</label>
                <select id="passengers" required>
                  <option value="1" data-i18n="passenger_1">1 Passenger</option>
                  <option value="2" data-i18n="passenger_2">2 Passengers</option>
                  <option value="3" data-i18n="passenger_3">3 Passengers</option>
                  <option value="4" data-i18n="passenger_4">4 Passengers</option>
                  <option value="5" data-i18n="passenger_5">5+ Passengers</option>
                </select>
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-full" data-i18n="search_flights">🔍 Search Flights</button>
          </form>
        </div>

        <div id="logisticsTab" class="tab-content" style="display:none;">
          <form id="logisticsForm" onsubmit="searchLogistics(event)">
            <div class="form-grid">
              <div class="form-group">
                <label data-i18n="package_type">Package Type</label>
                <select id="packageType" required>
                  <option value="" data-i18n="select_type">Select Type</option>
                  <option value="documents" data-i18n="docs">Documents</option>
                  <option value="parcel" data-i18n="parcel">Parcel < 5kg</option>
                  <option value="cargo" data-i18n="cargo">Cargo > 5kg</option>
                  <option value="express" data-i18n="express">Express Delivery</option>
                </select>
              </div>
              <div class="form-group">
                <label data-i18n="origin_country">Origin Country</label>
                <select id="originCountry" required>
                  <option value="" data-i18n="select_country">Select Country</option>
                </select>
              </div>
              <div class="form-group">
                <label data-i18n="dest_country">Destination Country</label>
                <select id="destCountry" required>
                  <option value="" data-i18n="select_country">Select Country</option>
                </select>
              </div>
              <div class="form-group">
                <label data-i18n="weight">Weight (kg)</label>
                <input type="number" id="weight" min="0.1" step="0.1" placeholder="0.0" required>
              </div>
            </div>
            <button type="submit" class="btn btn-primary btn-full" data-i18n="get_quote">📋 Get Quote</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <section class="results-section" id="resultsSection">
    <div class="container">
      <h2 class="section-title" data-i18n="available_flights">Available Flights</h2>
      <div id="flightResults"></div>
    </div>
  </section>

  <section class="reservations-section" id="reservations">
    <div class="container">
      <h2 class="section-title" data-i18n="my_reservations">My Reservations</h2>
      <div id="authPrompt" style="display:none;">
