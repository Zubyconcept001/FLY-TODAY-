window.completeCheckin = async function(docId, pnr) {
  try {
    const seatNumber = String.fromCharCode(65 + Math.floor(Math.random() * 6)) + (Math.floor(Math.random() * 30) + 1);
    
    await updateDoc(doc(db, 'bookings', docId), {
      checkedIn: true,
      checkinTime: new Date().toISOString(),
      seat: seatNumber
    });
    
    showToast('Check-in successful! Seat: ' + seatNumber);
    
    setTimeout(() => {
      lookupBooking();
    }, 1000);
    
  } catch (error) {
    console.error('Check-in error:', error);
    showToast('Check-in failed. Please try again.');
  }
}

