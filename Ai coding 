window.bookFlight = async function(flight, userPhone) {
  if (!currentUser) {
    showToast('Please sign in to book a flight');
    openAuthModal();
    return;
  }
  
  document.getElementById('paymentModal').classList.add('active');
  document.getElementById('paymentProcessing').classList.add('active');
  document.getElementById('ticketSuccess').style.display = 'none';
  
  try {
    const convertedPrice = convertCurrency(flight.priceUSD, selectedCurrency);
    const totalAmount = Math.round(convertedPrice * flight.passengers * 100);
    
    let phone = userPhone;
    if (!phone) {
      try {
        const userDoc = await getDocs(query(collection(db, 'users'), where('email', '==', currentUser.email)));
        if (!userDoc.empty) phone = userDoc.docs[0].data().phone;
      } catch (e) {}
    }
    
    setTimeout(async () => {
      const bookingId = 'FLY' + Date.now();
      const pnr = 'FT' + Math.random().toString(36).substring(2, 8).toUpperCase();
      const bookingData = {
        bookingId,
        pnr,
        userId: currentUser.uid,
        userEmail: currentUser.email,
        userName: currentUser.displayName || currentUser.email.split('@')[0],
        userPhone: phone || '',
        fcmToken: fcmToken || '',
        flight: flight,
        amount: totalAmount / 100,
        currency: selectedCurrency,
        passengers: flight.passengers,
        status: 'confirmed',
        paymentStatus: 'paid',
        checkedIn: false,
        currentGate: flight.gate,
        currentStatus: flight.status || 'on-time',
        createdAt: new Date().toISOString(),
        lastUpdated: new Date().toISOString()
      };
      
      try {
        const docRef = await addDoc(collection(db, 'bookings'), bookingData);
        currentBookingData = { ...bookingData, docId: docRef.id };
        
        await sendBookingConfirmationEmail(bookingData);
        
        if (phone) {
          await sendBookingSMS(bookingData);
        }
        
        document.getElementById('paymentProcessing').classList.remove('active');
        document.getElementById('ticketSuccess').style.display = 'block';
        generateQRCode(pnr);
        loadUserBookings();
        startFlightStatusMonitoring(pnr, flight.flightNumber);
      } catch (error) {
        console.error('Error saving booking:', error);
        showToast('Error processing booking. Please contact support.');
        closePaymentModal();
      }
    }, 2500);
    
  } catch (error) {
    showToast('Booking error. Please try again or contact support.');
    closePaymentModal();
  }
}

