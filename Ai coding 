// Google Wallet Integration
window.saveToGoogleWallet = function() {
  if (!currentBookingData) {
    showToast('No booking selected');
    return;
  }
  saveToGoogleWalletForBooking(currentBookingData);
}

window.saveToGoogleWalletForBooking = function(booking) {
  showToast('Opening Google Pay...');
  
  const googlePayObject = {
    iss: GOOGLE_WALLET_ISSUER_ID,
    aud: 'google',
    typ: 'savetowallet',
    iat: Math.floor(Date.now() / 1000),
    payload: {
      boardingPassObjects: [{
        id: `${GOOGLE_WALLET_ISSUER_ID}.${booking.pnr}`,
        classId: `${GOOGLE_WALLET_ISSUER_ID}.${GOOGLE_WALLET_CLASS_ID}`,
        state: 'ACTIVE',
        passengerName: booking.userName,
        reservationInfo: {
          confirmationCode: booking.pnr
        },
        flightInfo: {
          flightNumber: booking.flight.flightNumber,
          origin: {
            airportIataCode: booking.flight.from.code,
            gate: booking.currentGate || booking.flight.gate || 'TBA'
          },
          destination: {
            airportIataCode: booking.flight.to.code
          },
          operatingCarrier: {
            carrierIataCode: booking.flight.airline.substring(0, 2).toUpperCase()
          },
          scheduledDepartureDateTime: `${booking.flight.date}T${booking.flight.departure}:00`,
          scheduledArrivalDateTime: `${booking.flight.date}T${booking.flight.arrival}:00`
        },
        barcode: {
          type: 'QR_CODE',
          value: booking.pnr
        }
      }]
    }
  };
  
  console.log('Google Wallet Object:', googlePayObject);
  showToast('Google Pay integration ready. Server-side JWT signing required.');
}

// Handle browser back/forward
window.addEventListener('popstate', () => {
  if (window.location.pathname === '/checkin') {
    showCheckin({ preventDefault: () => {} });
  } else if (window.location.pathname === '/admin') {
    showAdmin({ preventDefault: () => {} });
  } else {
    showHome();
  }
});

document.addEventListener('DOMContentLoaded', () => {
  initLanguages();
  detectLocaleAndCurrency();
  populateCountries();
  
  const departInput = document.getElementById('departDate');
  const today = new Date().toISOString().split('T')[0];
  departInput.min = today;
  departInput.value = today;
  
  // Handle routes on load
  if (window.location.pathname === '/checkin') {
    showCheckin({ preventDefault: () => {} });
  } else if (window.location.pathname === '/admin') {
    showAdmin({ preventDefault: () => {} });
  }
});

