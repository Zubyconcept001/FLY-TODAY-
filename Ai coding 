              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
              Add to Wallet
            </button>
            <button class="btn btn-google" onclick='saveToGoogleWalletForBooking(${JSON.stringify(booking).replace(/'/g, "\\'")})'>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
              Google Pay
            </button>
          </div>
        </div>
      `;
    } else {
      resultDiv.innerHTML = `
        <div class="boarding-pass">
          <div class="boarding-pass-header">
            <h3>${booking.flight.airline}</h3>
            <div class="pnr-badge">${booking.pnr}</div>
          </div>
          ${generateBoardingPassHTML(booking)}
          <button class="btn btn-primary btn-full" onclick="completeCheckin('${docId}', '${booking.pnr}')" style="margin-top:1.5rem;">
            ✓ Complete Check-In
          </button>
        </div>
      `;
    }
    
  } catch (error) {
    console.error('Lookup error:', error);
    resultDiv.innerHTML = '<div class="flight-card" style="text-align:center;color:var(--danger);">Error looking up booking</div>';
  }
}

