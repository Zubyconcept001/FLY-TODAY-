window.searchFlights = function(e) {
  e.preventDefault();
  
  const fromAirport = document.getElementById('fromAirport').value;
  const toAirport = document.getElementById('toAirport').value;
  const date = document.getElementById('departDate').value;
  const passengers = document.getElementById('passengers').value;
  
  if (fromAirport === toAirport) {
    showToast('Origin and destination cannot be the same!');
    return;
  }
  
  const resultsSection = document.getElementById('resultsSection');
  const flightResults = document.getElementById('flightResults');
  
  flightResults.innerHTML = '<div class="loading-spinner"></div>';
  resultsSection.classList.add('active');
  resultsSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
  
  setTimeout(() => {
    const fromData = getAirportData(fromAirport);
    const toData = getAirportData(toAirport);
    const basePrice = calculateBasePrice(fromAirport, toAirport);
    
    const flights = generateFlights(fromData, toData, basePrice, passengers);
    displayFlights(flights, fromData, toData);
  }, 1000);
}

function getAirportData(code) {
  for (const country in globalAirports) {
    const airport = globalAirports[country].find(a => a.code === code);
    if (airport) return { ...airport, country };
  }
  return { code, name: 'Unknown', city: 'Unknown', country: 'Unknown' };
}

function calculateBasePrice(from, to) {
  return Math.floor(Math.random() * 400) + 200;
}

function generateFlights(from, to, basePrice, passengers) {
  const airlines = [
    { name: 'Emirates', logo: '✈️', code: 'EK' },
    { name: 'British Airways', logo: '✈️', code: 'BA' },
    { name: 'Lufthansa', logo: '✈️', code: 'LH' },
    { name: 'Delta Airlines', logo: '✈️', code: 'DL' },
    { name: 'Qatar Airways', logo: '✈️', code: 'QR' }
  ];
  
  return airlines.map((airline, i) => {
    const price = basePrice + (i * 50) + Math.floor(Math.random() * 100);
    const duration = Math.floor(Math.random() * 10) + 2;
    const departure = `${6 + i * 2}:00`;
    const arrival = `${6 + i * 2 + duration}:${Math.floor(Math.random() * 60).toString().padStart(2, '0')}`;
    const statuses = ['on-time', 'on-time', 'on-time', 'delayed'];
    const status = statuses[Math.floor(Math.random() * statuses.length)];
    
    return {
      airline: airline.name,
      airlineCode: airline.code,
      logo: airline.logo,
      priceUSD: price,
      departure,
      arrival,
      duration: `${duration}h ${Math.floor(Math.random() * 60)}m`,
      stops: i === 0 ? 'Direct' : '1 Stop',
      flightNumber: `${airline.code}${Math.floor(Math.random() * 900) + 100}`,
      from: from,
      to: to,
      passengers: passengers,
      date: document.getElementById('departDate').value,
      gate: String.fromCharCode(65 + Math.floor(Math.random() * 6)) + (Math.floor(Math.random() * 30) + 1),
      status: status
    };
  });
}

function displayFlights(flights, from, to) {
  const flightResults = document.getElementById('flightResults');
  flightResults.innerHTML = flights.map(flight => {
    const statusClass = flight.status === 'on-time' ? 'status-on-time' : flight.status === 'delayed' ? 'status-delayed' : 'status-cancelled';
    const statusText = flight.status === 'on-time' ? 'On Time' : flight.status === 'delayed' ? 'Delayed' : 'Cancelled';
    
    return `
    <div class="flight-card">
      <div class="flight-header">
        <div class="airline">
          <span class="badge badge-success">${flight.airline}</span>
          <span style="font-size:0.875rem; color:var(--gray);">${flight.flightNumber}</span>
          <span class="live-status-badge ${statusClass}">
            <span class="live-dot"></span>${statusText}
          </span>
        </div>
        <span class="badge badge-warning">${flight.stops}</span>
      </div>
      <div class="flight-route">
        <div class="route-info">
          <div class="route-time">${flight.departure}</div>
          <div class="route-city">${from.city} (${from.code})</div>
          <div style="font-size:0.75rem; color:var(--gray); margin-top:0.25rem;">Gate: ${flight.gate}</div>
