}

function initLanguages() {
  const selector = document.getElementById('languageSelector');
  Object.keys(languages).forEach(code => {
    if (code !== 'en') {
      const option = document.createElement('option');
      option.value = code;
      option.textContent = languages[code];
      selector.appendChild(option);
    }
  });
  
  const savedLang = localStorage.getItem('flytoday_language');
  const browserLang = navigator.language.split('-')[0];
  selectedLanguage = savedLang || (languages[browserLang] ? browserLang : 'en');
  selector.value = selectedLanguage;
  applyTranslations();
}

window.changeLanguage = function() {
  selectedLanguage = document.getElementById('languageSelector').value;
  localStorage.setItem('flytoday_language', selectedLanguage);
  applyTranslations();
  showToast(`Language changed to ${languages[selectedLanguage]}`);
}

function applyTranslations() {
  const dict = translations[selectedLanguage] || translations['en'];
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n');
    if (dict[key]) {
      if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {
        el.placeholder = dict[key];
      } else if (el.tagName === 'SMALL') {
        el.textContent = dict[key];
      } else {
        el.textContent = dict[key];
      }
    }
  });
}

async function detectLocaleAndCurrency() {
  try {
    const response = await fetch('https://ipapi.co/json/');
    const data = await response.json();
    const countryCode = data.country_code;
    
    const countryToCurrency = { 'US': 'USD', 'CA': 'USD', 'NG': 'NGN', 'GB': 'GBP', 'DE': 'EUR', 'FR': 'EUR', 'ES': 'EUR', 'IT': 'EUR', 'NL': 'EUR' };
    
    selectedCurrency = countryToCurrency[countryCode] || 'USD';
    document.getElementById('currencySelector').value = selectedCurrency;
    
    if (!localStorage.getItem('flytoday_language') && countryCode) {
      const countryToLang = { 'US': 'en', 'GB': 'en', 'CA': 'en', 'FR': 'fr', 'DE': 'de', 'ES': 'es', 'IT': 'it', 'PT': 'pt', 'BR': 'pt', 'RU': 'ru', 'CN': 'zh', 'JP': 'ja', 'KR': 'ko', 'IN': 'hi', 'SA': 'ar' };
      const detectedLang = countryToLang[countryCode];
      if (detectedLang && languages[detectedLang]) {
        selectedLanguage = detectedLang;
        document.getElementById('languageSelector').value = selectedLanguage;
        applyTranslations();
      }
    }
    
    fetchFXRates();
  } catch (e) {
    selectedCurrency = 'USD';
    document.getElementById('currencySelector').value = 'USD';
  }
}

async function fetchFXRates() {
  try {
    const response = await fetch('https://api.exchangerate-api.com/v4/latest/USD');
    const data = await response.json();
    fxRates = { USD: 1, EUR: data.rates.EUR || 0.92, GBP: data.rates.GBP || 0.79, NGN: data.rates.NGN || 1650 };
    updatePricesDisplayed();
  } catch (e) {
    console.log('Using fallback FX rates');
  }
}

function populateCountries() {
  const countries = Object.keys(globalAirports).sort();
  const selectors = ['fromCountry', 'toCountry', 'originCountry', 'destCountry'];
  
  selectors.forEach(id => {
    const select = document.getElementById(id);
    if (select) {
      countries.forEach(country => {
        const option = document.createElement('option');
        option.value = country;
        option.textContent = country;
        select.appendChild(option);
      });
    }
  });
}

window.updateAirports = function(type) {
  const countryId = type + 'Country';
  const airportId = type + 'Airport';
  const country = document.getElementById(countryId).value;
  const airportSelect = document.getElementById(airportId);
  
  airportSelect.innerHTML = '<option value="">Select Airport</option>';
  
  if (country && globalAirports[country]) {
    globalAirports[country].forEach(airport => {
      const option = document.createElement('option');
      option.value = airport.code;
      option.textContent = `${airport.code} - ${airport.name} (${airport.city})`;
      airportSelect.appendChild(option);
    });
  }
}

function convertCurrency(amountUSD, toCurrency) {
  return amountUSD * fxRates[toCurrency];
}

function formatCurrency(amount, currency) {
  const symbols = { USD: '$', EUR: '€', GBP: '£', NGN: '₦' };
  return `${symbols[currency] || currency} ${amount.toFixed(2)}`;
}

window.changeCurrency = function() {
  selectedCurrency = document.getElementById('currencySelector').value;
  updatePricesDisplayed();
  showToast(`Currency changed to ${selectedCurrency}`);
}

function updatePricesDisplayed() {
  const priceElements = document.querySelectorAll('.price');
  priceElements.forEach(el => {
    const usdAmount = parseFloat(el.dataset.usd || el.textContent.replace(/[^0-9.]/g, ''));
    if (!isNaN(usdAmount)) {
      const converted = convertCurrency(usdAmount, selectedCurrency);
      el.textContent = formatCurrency(converted, selectedCurrency);
      el.dataset.usd = usdAmount;
    }
  });
}

