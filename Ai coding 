// Live Flight Status Integration - AviationStack
async function fetchFlightStatus(flightNumber, date) {
  try {
    const response = await fetch(`${AVIATIONSTACK_BASE_URL}/flights?access_key=${AVIATIONSTACK_API_KEY}&flight_iata=${flightNumber}&flight_date=${date}`);
    const data = await response.json();
    
    if (data.data && data.data.length > 0) {
      const flight = data.data[0];
      return {
        status: flight.flight_status || 'scheduled',
        gate: flight.departure?.gate || flight.flight.gate || 'TBA',
        terminal: flight.departure?.terminal || 'TBA',
        estimated: flight.departure?.estimated || null,
        actual: flight.departure?.actual || null,
        delay: flight.departure?.delay || 0
      };
    }
    return null;
  } catch (error) {
    console.error('AviationStack API error:', error);
    return null;
  }
}

function startFlightStatusMonitoring(pnr, flightNumber) {
  // Auto-refresh every 5 minutes
  if (statusUpdateInterval) clearInterval(statusUpdateInterval);
  
  const updateStatus = async () => {
    const today = new Date().toISOString().split('T')[0];
    const status = await fetchFlightStatus(flightNumber, today);
    
    if (status) {
      console.log('Live status update:', status);
      // Update Firestore and trigger notification if gate/time changed
      try {
        const q = query(collection(db, 'bookings'), where('pnr', '==', pnr));
        const snapshot = await getDocs(q);
        if (!snapshot.empty) {
          const bookingDoc = snapshot.docs[0];
          const currentData = bookingDoc.data();
          
          const needsUpdate = status.gate !== currentData.currentGate || status.status !== currentData.currentStatus;
          
          if (needsUpdate) {
            await updateDoc(doc(db, 'bookings', bookingDoc.id), {
              currentGate: status.gate,
              currentStatus: status.status,
              lastUpdated: new Date().toISOString()
            });
            
            if (currentData.fcmToken) {
              sendFlightNotification(currentData.fcmToken, pnr, status);
            }
          }
        }
      } catch (e) {
        console.error('Status update error:', e);
      }
    }
  };
  
  updateStatus(); // Initial call
  statusUpdateInterval = setInterval(updateStatus, 5 * 60 * 1000); // 5 minutes
}

